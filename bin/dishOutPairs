#!/bin/bash

printUsage()
{
    dishOutSections --help 2>&1 | sed \
	-e '1s#^.*$#Print consecutive pairs of lines of a source file on each invocation.#' \
	-e 's/\([[:space:]]\)section/\1pair/g' \
	-e '/^ *\(--lines\|--blocks\|--section-separator|-S\)/b removeOptionLoop' \
	-e '/^Usage:$/N' -e '/\(^\|\n\)Usage: */{ s/\(^\|\n\)\(Usage: *\)\?\([^ |]\+ \)*dishOutSections /\1\2'"$(basename "$1")"' /; s/ \[--lines|--blocks LINE-CNT|-S|--section-separator PATTERN\]//; }' \
	-e b -e :removeOptionLoop -e '{ /\n *\(--lines\|--blocks\|--section-separator|-S\)[^\n]*$/{ N; b removeOptionLoop; }; /\n *--[^\n]*$\|\n[^	 ]\|\n$/{ s/^\(.*\n\)\?//; b; }; N; b removeOptionLoop; }'
}
case "$1" in
    --help|-h|-\?)	shift; printUsage "$0"; exit 0;;
esac

exec dishOutSections --blocks 2 "$@"
