#!/bin/bash
set -e

printShortUsage()
{
    # Note: short followed by long option; if the user knows the short one, she can
    # skim the long one.
    printf 'Usage: cat FILE [...] | %q %s\n' "$(basename "$1")" '[-a|--append] [--sudo] [--] TARGET-FILE [-?|-h|--help]'
}
printUsage()
{
    # This is the short help when launched with no or incorrect arguments.
    # It is printed to stderr to avoid accidental processing.
    printShortUsage "$1" >&2
    printf >&2 '\nTry %q --help for more information.\n' "$(basename "$1")"
}
printLongUsage()
{
    # This is the long "man page" when launched with the help argument.
    # It is printed to stdout to allow paging with 'more'.
    cat <<HELPDESCRIPTION
Create a TARGET-FILE from standard input, automatically creating missing parent
directories if necessary.
HELPDESCRIPTION
    echo
    printShortUsage "$1"
    echo
    cat <<HELPTEXT
    --append|-a		Append to TARGET-FILE instead of overwriting it.
    --sudo		Create with sudo unless the target directory is
			writeable by the current user or we're already running
			as the superuser.
HELPTEXT
}

sudoArg=
redir='>'
typeset -a teeArg=()
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	    shift; printLongUsage "$0"; exit 0;;
	--append|-a)	    teeArg=("$1"); shift; redir='>>';;
	--sudo)		    shift; sudoArg="${SUDO:-sudo}";;
	--)		    shift; break;;
	-*)		    { echo "ERROR: Unknown option \"$1\"!"; echo; printUsage "$0"; } >&2; exit 2;;
	*)		    break;;
    esac
done
if [ $# -ne 1 ]; then
    printUsage "$0" >&2
    exit 2
fi
targetFilespec="${1:?}"; shift

SUDO="$sudoArg"; [ $EUID -eq 0 ] || [ -w "$targetDirspec" ] && SUDO=''

targetDirspec="$(dirname -- "$targetFilespec")"
[ -d "$targetDirspec" ] || $SUDO mkdir --parents -- "$targetDirspec" || exit $?

if [ -n "$SUDO" ]; then
    $SUDO tee "${teeArg[@]}" -- "$targetFilespec" >/dev/null
else
    eval "cat $redir \"\$targetFilespec\""
fi
